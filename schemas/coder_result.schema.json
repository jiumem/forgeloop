{
  "$defs": {
    "CheckResult": {
      "description": "单项检查的执行结果。",
      "properties": {
        "check_name": {
          "description": "检查名称",
          "minLength": 1,
          "title": "Check Name",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/CheckStatus",
          "description": "执行状态"
        },
        "message": {
          "default": "",
          "description": "附加说明，skipped 时必须填原因",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "check_name",
        "status"
      ],
      "title": "CheckResult",
      "type": "object"
    },
    "CheckStatus": {
      "description": "单项检查的执行状态。",
      "enum": [
        "passed",
        "failed",
        "skipped",
        "error"
      ],
      "title": "CheckStatus",
      "type": "string"
    }
  },
  "description": "执行结果模型 — 四个核心模型之一。\n\n关键裁决:\n- coder_result 可以声明\"我完成了什么\"，不能宣布\"任务已通过\"\n- 未执行的检查必须显式写明原因\n- 相邻内容未做不是缺陷，而是合同的一部分\n\n五个面:\n- 代码面: files_changed\n- 法位面: contracts_addressed\n- 清理面: cleanups_done\n- 验证面: check_results\n- 边界面: out_of_scope_notes",
  "properties": {
    "task_id": {
      "description": "关联的任务 ID",
      "minLength": 1,
      "title": "Task Id",
      "type": "string"
    },
    "round_no": {
      "description": "第几轮执行",
      "minimum": 1,
      "title": "Round No",
      "type": "integer"
    },
    "files_changed": {
      "description": "变更的文件路径列表",
      "items": {
        "type": "string"
      },
      "title": "Files Changed",
      "type": "array"
    },
    "contracts_addressed": {
      "description": "收正的接口 / seam / contract 列表",
      "items": {
        "type": "string"
      },
      "title": "Contracts Addressed",
      "type": "array"
    },
    "cleanups_done": {
      "description": "删除或清理的旧代码 / 旧命名 / 旧路径",
      "items": {
        "type": "string"
      },
      "title": "Cleanups Done",
      "type": "array"
    },
    "check_results": {
      "description": "各项检查的执行结果",
      "items": {
        "$ref": "#/$defs/CheckResult"
      },
      "title": "Check Results",
      "type": "array"
    },
    "out_of_scope_notes": {
      "description": "刻意未做的相邻内容说明",
      "items": {
        "type": "string"
      },
      "title": "Out Of Scope Notes",
      "type": "array"
    },
    "summary": {
      "default": "",
      "description": "本轮执行的自然语言摘要（解释用，非业务真值）",
      "title": "Summary",
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "round_no"
  ],
  "title": "CoderResult",
  "type": "object"
}
