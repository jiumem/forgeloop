{
  "$defs": {
    "Finding": {
      "description": "结构化 finding — reviewer 产出的单个问题。\n\n法定字段：设计方案要求一个合格 finding 至少同时包含以下七个字段。\n少任何一项，controller 的自动裁决都会变弱。",
      "properties": {
        "finding_key": {
          "description": "Finding 唯一标识键",
          "minLength": 1,
          "title": "Finding Key",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "description": "严重级别"
        },
        "summary": {
          "description": "问题摘要",
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "why_it_matters": {
          "description": "为什么重要",
          "minLength": 1,
          "title": "Why It Matters",
          "type": "string"
        },
        "in_scope": {
          "description": "是否在当前任务 scope 内",
          "title": "In Scope",
          "type": "boolean"
        },
        "scope_basis": {
          "description": "scope 判定依据（引用 task_packet 的哪条边界）",
          "minLength": 1,
          "title": "Scope Basis",
          "type": "string"
        },
        "blocks_promotion": {
          "description": "是否阻断晋级",
          "title": "Blocks Promotion",
          "type": "boolean"
        }
      },
      "required": [
        "finding_key",
        "severity",
        "summary",
        "why_it_matters",
        "in_scope",
        "scope_basis",
        "blocks_promotion"
      ],
      "title": "Finding",
      "type": "object"
    },
    "NextTaskRecommendation": {
      "description": "下一任务候选建议（Reviewer 可建议，不可决定）。",
      "properties": {
        "task_id": {
          "description": "建议的下一任务 ID",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Task Id",
          "type": "string"
        },
        "rationale": {
          "default": "",
          "description": "推荐理由",
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "task_id"
      ],
      "title": "NextTaskRecommendation",
      "type": "object"
    },
    "PromotionReadiness": {
      "description": "晋级就绪度评估。",
      "properties": {
        "ready": {
          "description": "是否具备晋级条件",
          "title": "Ready",
          "type": "boolean"
        },
        "rationale": {
          "default": "",
          "description": "判定理由",
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "ready"
      ],
      "title": "PromotionReadiness",
      "type": "object"
    },
    "Severity": {
      "description": "Finding 严重级别。",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ],
      "title": "Severity",
      "type": "string"
    },
    "TaskVerdict": {
      "description": "当前任务的总体结论。",
      "enum": [
        "clean",
        "needs_fix",
        "needs_human_ruling"
      ],
      "title": "TaskVerdict",
      "type": "string"
    }
  },
  "description": "审查结果模型 — 四个核心模型之一。\n\n四个区块:\n- findings: 结构化问题列表\n- current_task_verdict: 当前任务总体结论\n- promotion_readiness: 晋级就绪度\n- next_task_recommendations: 候选下一任务（建议，非命令）\n\n关键裁决:\n- Reviewer 关注的是实质性问题，不是风格偏好\n- Reviewer 可以建议下一任务，但不能直接决定调度\n- \"看不清\"必须诚实输出 needs_human_ruling",
  "properties": {
    "task_id": {
      "description": "关联的任务 ID",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_-]+$",
      "title": "Task Id",
      "type": "string"
    },
    "round_no": {
      "description": "第几轮审查",
      "minimum": 1,
      "title": "Round No",
      "type": "integer"
    },
    "findings": {
      "description": "结构化 finding 列表",
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "current_task_verdict": {
      "$ref": "#/$defs/TaskVerdict",
      "description": "当前任务总体结论"
    },
    "promotion_readiness": {
      "$ref": "#/$defs/PromotionReadiness",
      "description": "晋级就绪度评估"
    },
    "next_task_recommendations": {
      "description": "下一任务候选建议列表",
      "items": {
        "$ref": "#/$defs/NextTaskRecommendation"
      },
      "title": "Next Task Recommendations",
      "type": "array"
    },
    "summary": {
      "default": "",
      "description": "审查摘要（解释用，非业务真值）",
      "title": "Summary",
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "round_no",
    "current_task_verdict",
    "promotion_readiness"
  ],
  "title": "ReviewResult",
  "type": "object"
}
